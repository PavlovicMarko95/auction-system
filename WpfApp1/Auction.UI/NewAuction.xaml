<Window x:Class="Auction.UI.NewAuction"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Auction.UI"
        mc:Ignorable="d"
        Title="NewAuction" Height="300" Width="250" Loaded="Window_loaded">
    <Grid>
        <StackPanel Height="200" Width="130" Orientation="Vertical">
            <Label Content="AuctionName"/>
            <TextBox Text="{Binding CurrentAuction.AuctionName, ValidatesOnNotifyDataErrors=True}"/>
            <Label Content="Price"/>
            <TextBox Text="{Binding CurrentAuction.Cena, ValidatesOnDataErrors=True}"/>
            <Button Command="{Binding SaveCommand}" Height="20" Width="80" Margin="10,10,10,10" HorizontalAlignment="Right">Save</Button>
        </StackPanel>
    </Grid>
</Window>
