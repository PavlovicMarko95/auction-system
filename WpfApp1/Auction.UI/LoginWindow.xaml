<Window x:Class="Auction.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Auction.UI"
        mc:Ignorable="d"
        Title="LoginWindow" Height="300" Width="250">
    <Grid>

        <StackPanel Height="200" Width="130" Orientation="Vertical">
            <Label Content="User Name">
            </Label>
            <TextBox  Text="{Binding FirstName}" Name ="FirstName"></TextBox>
            <Label  Content="Pasword"></Label>
            <TextBox Text="{Binding LastName}" Name="LastName"></TextBox>
            <Button Width="80" Height="20" Margin="10,10,10,10" HorizontalAlignment="Right" RenderTransformOrigin="0.5,0.5" Click="Button_Click" >Login</Button>
            <TextBlock HorizontalAlignment="Right" Margin="10,0,10,10">
                <Hyperlink Click="BezPrijave">Guest login</Hyperlink>
            </TextBlock>
        </StackPanel>

    </Grid>
</Window>
